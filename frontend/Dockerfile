FROM node:20-slim AS builder

WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

ARG VITE_NEIGHBORHOOD_API
ARG VITE_PREDICTOR_API
ARG VITE_DASHBOARD_API
ARG VITE_RECOMMENDER_API

ENV VITE_NEIGHBORHOOD_API=$VITE_NEIGHBORHOOD_API
ENV VITE_PREDICTOR_API=$VITE_PREDICTOR_API
ENV VITE_DASHBOARD_API=$VITE_DASHBOARD_API
ENV VITE_RECOMMENDER_API=$VITE_RECOMMENDER_API

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]